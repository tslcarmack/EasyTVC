{
  "name": "easytvc",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "dev:web": "turbo dev --filter=@easytvc/web",
    "dev:api": "turbo dev --filter=@easytvc/api",
    "build:web": "turbo build --filter=@easytvc/web",
    "build:api": "turbo build --filter=@easytvc/api",
    "db:migrate": "pnpm --filter @easytvc/api db:migrate",
    "db:push": "pnpm --filter @easytvc/api db:push",
    "db:studio": "pnpm --filter @easytvc/api db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.29.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  }
}
